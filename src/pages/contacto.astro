const testimonios = [
  {
    cita: 'El resultado final fue exactamente lo que esperábamos, y más.',
    nombre: 'Laura M.',
    empresa: 'Estudio Nómada',
  },
  {
    cita: 'Sin estrés, sin complicaciones y exactamente lo que necesitábamos.',
    nombre: 'Carla P.',
    empresa: 'Carla Pereira Coaching',
  },
  {
    cita: 'Trajo mi visión a la vida y la mejoró. No hubiera podido hacerlo sin ella.',
    nombre: 'Marta R.',
    empresa: 'Marta Roca Studio',
  },
  {
    cita: 'Fue como si me conociera de toda la vida. El proceso fue fluido y el resultado, increíble.',
    nombre: 'Sofía G.',
    empresa: 'Sofía G. Photography',
  },
];
---

<BaseLayout
  title="Trabaja conmigo — AndreaFusion"
  description="Auditoría web, identidad de marca o web a medida. Webs con personalidad para marcas que quieren diferenciarse."
>
  <main class="tmc-page">

    <!-- ══════════════════════════════════════
         HERO
    ══════════════════════════════════════ -->
    <header class="tmc-hero">
      <div class="tmc-hero__inner">

        <p class="section-num">Trabaja conmigo</p>

        <h1 class="tmc-hero__title">
          Estás perdiendo clientes
          <em>cada día que tu web</em>
          <em class="em-lime">no te representa.</em>
        </h1>

        <p class="tmc-hero__sub">
          Te ayudo a crear la marca y la web que por fin están a la altura
          de lo que haces — para que la gente vea tu valor y esté lista para comprar.
        </p>

        <a href="#servicios" class="tmc-hero__cta">
          Ver cómo puedo ayudarte
        </a>

      </div>

      <div class="tmc-hero__deco" aria-hidden="true"></div>
    </header>

    <!-- ══════════════════════════════════════
         MARQUEE
    ══════════════════════════════════════ -->
    <div class="tmc-marquee" aria-hidden="true">
      <div class="tmc-marquee__track">
        <span>WEBS CON PERSONALIDAD</span>
        <span class="tmc-marquee__sep">·</span>
        <span>DISEÑO QUE CONVIERTE</span>
        <span class="tmc-marquee__sep">·</span>
        <span>CÓDIGO LIMPIO</span>
        <span class="tmc-marquee__sep">·</span>
        <span>IDENTIDAD QUE IMPACTA</span>
        <span class="tmc-marquee__sep">·</span>
        <span>WEBS CON PERSONALIDAD</span>
        <span class="tmc-marquee__sep">·</span>
        <span>DISEÑO QUE CONVIERTE</span>
        <span class="tmc-marquee__sep">·</span>
        <span>CÓDIGO LIMPIO</span>
        <span class="tmc-marquee__sep">·</span>
        <span>IDENTIDAD QUE IMPACTA</span>
        <span class="tmc-marquee__sep">·</span>
        <!-- duplicado para loop infinito -->
        <span>WEBS CON PERSONALIDAD</span>
        <span class="tmc-marquee__sep">·</span>
        <span>DISEÑO QUE CONVIERTE</span>
        <span class="tmc-marquee__sep">·</span>
        <span>CÓDIGO LIMPIO</span>
        <span class="tmc-marquee__sep">·</span>
        <span>IDENTIDAD QUE IMPACTA</span>
        <span class="tmc-marquee__sep">·</span>
        <span>WEBS CON PERSONALIDAD</span>
        <span class="tmc-marquee__sep">·</span>
        <span>DISEÑO QUE CONVIERTE</span>
        <span class="tmc-marquee__sep">·</span>
        <span>CÓDIGO LIMPIO</span>
        <span class="tmc-marquee__sep">·</span>
        <span>IDENTIDAD QUE IMPACTA</span>
        <span class="tmc-marquee__sep">·</span>
      </div>
    </div>

    <!-- ══════════════════════════════════════
         SERVICIOS NUMERADOS
    ══════════════════════════════════════ -->
    <section class="tmc-servicios" id="servicios" aria-labelledby="servicios-heading">
      <div class="tmc-servicios__inner">

        <div class="tmc-servicios__header">
          <p class="section-num">Servicios</p>
          <h2 class="tmc-servicios__title" id="servicios-heading">
            ¿Qué estás<br>
            <em>buscando?</em>
          </h2>
        </div>

        <!-- Tabs de navegación (desktop) / acordeón (mobile) -->
        <nav class="tmc-tabs" role="tablist" aria-label="Servicios disponibles">
          {servicios.map((s, i) => (
            <button
              class={`tmc-tab${i === 0 ? ' is-active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${i}`}
              id={`tab-${i}`}
              data-index={i}
              data-hash={`servicio-${i}`}
            >
              <span class="tmc-tab__num">{s.num}</span>
              <span class="tmc-tab__label">{s.tag}</span>
            </button>
          ))}
        </nav>

        <!-- Paneles de contenido -->
        {servicios.map((s, i) => (
          <div
            class={`tmc-panel${i === 0 ? ' is-active' : ''}`}
            role="tabpanel"
            id={`panel-${i}`}
            aria-labelledby={`tab-${i}`}
            hidden={i !== 0}
          >
            <div class="tmc-panel__layout">

              <!-- Columna info -->
              <div class="tmc-panel__info">
                <p class="tmc-panel__bajada">{s.bajada}</p>
                <p class="tmc-panel__desc">{s.descripcion}</p>

                <div class="tmc-panel__entregables">
                  <p class="tmc-panel__ent-label">Qué incluye:</p>
                  <ul role="list">
                    {s.entregables.map((e) => (
                      <li>
                        <span class="tmc-panel__ent-dot" aria-hidden="true">—</span>
                        {e}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <!-- Columna CTA + precio -->
              <div class="tmc-panel__cta-col">
                <div class="tmc-panel__precio-card">
                  <p class="tmc-panel__titulo">{s.titulo}</p>
                  <p class="tmc-panel__precio">{s.precio}</p>
                  <a href={s.href} class="tmc-panel__btn">
                    {s.cta}
                    <span aria-hidden="true"> ↗</span>
                  </a>
                </div>
              </div>

            </div>
          </div>
        ))}

      </div>
    </section>

    <!-- ══════════════════════════════════════
         TESTIMONIOS
    ══════════════════════════════════════ -->
    <section class="tmc-testis" aria-labelledby="testis-heading">
      <div class="tmc-testis__inner">

        <p class="section-num-light">Clientes</p>

        <div class="tmc-testis__grid">
          {testimonios.map((t) => (
            <article class="tmc-testi-card">
              <blockquote class="tmc-testi-card__quote">
                <p>"{t.cita}"</p>
              </blockquote>
              <footer class="tmc-testi-card__footer">
                <span class="tmc-testi-card__nombre">{t.nombre}</span>
                <span class="tmc-testi-card__empresa">{t.empresa}</span>
              </footer>
            </article>
          ))}
        </div>

      </div>

      <p class="tmc-testis__ghost" aria-hidden="true">AF</p>
    </section>

    <!-- ══════════════════════════════════════
         FORMULARIO DE CONTACTO
    ══════════════════════════════════════ -->
    <section class="tmc-form-sec" id="contacto" aria-labelledby="form-heading">
      <div class="tmc-form-sec__inner">

        <!-- Cabecera de sección -->
        <div class="tmc-form-sec__header">
          <p class="section-num">Empecemos</p>
          <h2 class="tmc-form-sec__title" id="form-heading">
            Cuéntame tu proyecto
          </h2>
          <p class="tmc-form-sec__sub">
            ¿Lista para dar el paso? Rellena el formulario y cuéntame en qué
            punto estás. Sin presión ni guiones preparados.
          </p>
          <p class="tmc-form-sec__email-alt">
            O escríbeme directamente a{' '}
            <a
              href="mailto:andreafusiondigital@gmail.com"
              class="tmc-form-sec__email-link"
              aria-label="Enviar email a Andrea"
            >
              andreafusiondigital@gmail.com
            </a>
          </p>

          <div class="tmc-form-sec__avail">
            <span class="tmc-form-sec__dot" aria-hidden="true"></span>
            <p>Available worldwide · Based in Spain</p>
          </div>
        </div>

        <!-- Formulario -->
        <div class="tmc-form-wrap">
          <form
            class="tmc-form"
            action={`https://formspree.io/f/${FORMSPREE_ID}`}
            method="POST"
            novalidate
            id="tmc-contact-form"
          >
            <div class="form-row">
              <div class="form-field">
                <label class="form-label" for="nombre">Nombre</label>
                <input
                  class="form-input"
                  type="text"
                  id="nombre"
                  name="nombre"
                  autocomplete="given-name"
                  required
                  placeholder="Tu nombre"
                />
              </div>

              <div class="form-field">
                <label class="form-label" for="email">Email</label>
                <input
                  class="form-input"
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  required
                  placeholder="tu@email.com"
                />
              </div>
            </div>

            <div class="form-field">
              <label class="form-label" for="servicio">¿Qué servicio te interesa?</label>
              <select class="form-input form-input--select" id="servicio" name="servicio">
                <option value="">Selecciona un servicio…</option>
                <option value="auditoria">Auditoría de marca / web</option>
                <option value="landing">Landing page estratégica</option>
                <option value="web">Web a medida</option>
                <option value="otro">Aún no lo tengo claro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-label" for="proyecto">Tu proyecto en pocas palabras</label>
              <input
                class="form-input"
                type="text"
                id="proyecto"
                name="proyecto"
                required
                placeholder="Ej: Quiero rediseñar mi web de coaching"
              />
            </div>

            <div class="form-field">
              <label class="form-label" for="mensaje">
                ¿En qué punto estás y hacia dónde quieres ir?
              </label>
              <textarea
                class="form-input form-input--textarea"
                id="mensaje"
                name="mensaje"
                rows="5"
                required
                placeholder="Cuéntame qué está pasando con tu marca o web ahora mismo y qué te gustaría cambiar. Sin presión."
              ></textarea>
            </div>

            <!-- Anti-spam -->
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="_next" value="/trabaja-conmigo?enviado=true" />

            <div class="form-footer">
              <button class="form-submit" type="submit" id="form-submit">
                <span class="form-submit__text">Enviar solicitud</span>
                <span class="form-submit__icon" aria-hidden="true">↗</span>
              </button>
              <p class="form-note">Respondo normalmente en 24–48h.</p>
            </div>
          </form>

          <div class="form-success" id="form-success" aria-live="polite" hidden>
            <span class="form-success__icon" aria-hidden="true">✓</span>
            <h3>¡Solicitud enviada!</h3>
            <p>Gracias por escribirme. Te respondo en 24–48h.</p>
          </div>
        </div>

      </div>
    </section>

  </main>
</BaseLayout>

<script>
// ── Formspree: estado enviado ──
if (window.location.search.includes('enviado=true')) {
  const form    = document.getElementById('tmc-contact-form');
  const success = document.getElementById('form-success');
  if (form)    form.setAttribute('hidden', '');
  if (success) success.removeAttribute('hidden');
}

// ── Feedback visual en el botón ──
const form = document.getElementById('tmc-contact-form') as HTMLFormElement | null;
const btn  = document.getElementById('form-submit') as HTMLButtonElement | null;
form?.addEventListener('submit', () => {
  if (!btn) return;
  btn.disabled = true;
  const txt = btn.querySelector('.form-submit__text');
  if (txt) txt.textContent = 'Enviando…';
});

// ── Lógica de tabs ──
const tabs   = document.querySelectorAll<HTMLButtonElement>('.tmc-tab');
const panels = document.querySelectorAll<HTMLElement>('.tmc-panel');

function activateTab(idx: number) {
  tabs.forEach((t, i) => {
    const active = i === idx;
    t.classList.toggle('is-active', active);
    t.setAttribute('aria-selected', active ? 'true' : 'false');
  });
  panels.forEach((p, i) => {
    const active = i === idx;
    p.classList.toggle('is-active', active);
    active ? p.removeAttribute('hidden') : p.setAttribute('hidden', '');
  });
}

// Clicks en tabs
tabs.forEach((tab) => {
  tab.addEventListener('click', () => {
    activateTab(Number(tab.dataset.index));
  });
});

// ── Activación por hash en la URL ──
// Los links de /links usan #servicio-0, #servicio-1, #servicio-2
function activateFromHash() {
  const hash = window.location.hash.replace('#', ''); // ej: "servicio-1"
  const matchedTab = Array.from(tabs).find(t => t.dataset.hash === hash);
  if (matchedTab) {
    const idx = Number(matchedTab.dataset.index);
    activateTab(idx);
    // Scroll suave hasta la sección de servicios
    setTimeout(() => {
      document.getElementById('servicios')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 80);
  }
}

// Al cargar la página (por si viene con hash desde /links)
activateFromHash();
// Al cambiar el hash sin recargar (navegación interna)
window.addEventListener('hashchange', activateFromHash);
</script>

<style>
/* ══════════════════════════════════
   BASE
══════════════════════════════════ */
.tmc-page {
  padding-top: 80px;
}

/* ══════════════════════════════════
   HERO
══════════════════════════════════ */
.tmc-hero {
  position: relative;
  background: var(--color-bg-hero);
  overflow: hidden;
  padding: 4rem 1.5rem 5rem;
}

.tmc-hero__inner {
  position: relative;
  z-index: 2;
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
}

.tmc-hero__title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(2.8rem, 9vw, 7.5rem);
  line-height: 0.97;
  letter-spacing: -0.035em;
  color: var(--color-text-hero);
}

.tmc-hero__title em {
  display: block;
  font-style: italic;
}

.tmc-hero__title .em-lime {
  color: var(--color-accent-lime);
}

.tmc-hero__sub {
  font-family: var(--font-body);
  font-size: clamp(1rem, 2.2vw, 1.12rem);
  line-height: 1.75;
  color: rgba(245, 238, 230, 0.68);
  max-width: 50ch;
}

.tmc-hero__cta {
  display: inline-flex;
  align-self: flex-start;
  padding: 0.9em 2.4em;
  background: var(--color-accent-lime);
  color: var(--color-text-dark);
  font-family: var(--font-body);
  font-size: 0.95rem;
  font-weight: 700;
  border-radius: var(--radius-btn);
  box-shadow: var(--shadow-btn);
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.tmc-hero__cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(200, 241, 53, 0.45);
}

.tmc-hero__deco {
  position: absolute;
  bottom: -6rem;
  right: -6rem;
  width: clamp(260px, 55vw, 480px);
  height: clamp(260px, 55vw, 480px);
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(200, 241, 53, 0.09) 0%,
    rgba(245, 184, 208, 0.07) 50%,
    transparent 70%
  );
  pointer-events: none;
  z-index: 1;
}

@media (min-width: 768px) {
  .tmc-hero { padding: 6rem 4rem 7rem; }
}

/* ══════════════════════════════════
   MARQUEE
══════════════════════════════════ */
.tmc-marquee {
  background: var(--color-accent-lime);
  overflow: hidden;
  padding: 0.85rem 0;
  white-space: nowrap;
}

.tmc-marquee__track {
  display: inline-flex;
  align-items: center;
  gap: 1.5rem;
  animation: marquee 28s linear infinite;
  will-change: transform;
}

.tmc-marquee__track span {
  font-family: var(--font-body);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-text-dark);
  flex-shrink: 0;
}

.tmc-marquee__sep {
  opacity: 0.5;
}

@keyframes marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

@media (prefers-reduced-motion: reduce) {
  .tmc-marquee__track { animation: none; }
}

/* ══════════════════════════════════
   SERVICIOS
══════════════════════════════════ */
.tmc-servicios {
  background: var(--color-bg-light);
  border-radius: 0;
}

.tmc-servicios__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 5rem 1.5rem 6rem;
  display: flex;
  flex-direction: column;
  gap: 3rem;
}

.tmc-servicios__header {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.tmc-servicios__title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(2.5rem, 7vw, 5.5rem);
  line-height: 1.0;
  letter-spacing: -0.03em;
  color: var(--color-text-dark);
}

.tmc-servicios__title em {
  font-style: italic;
  color: var(--color-text-mid);
}

/* ── Tabs de navegación ── */
.tmc-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.tmc-tab {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.7em 1.4em;
  border: 1.5px solid rgba(90, 58, 122, 0.2);
  border-radius: var(--radius-btn);
  background: transparent;
  cursor: pointer;
  transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
  font-family: var(--font-body);
  color: var(--color-text-mid);
}

.tmc-tab:hover {
  border-color: var(--color-text-mid);
}

.tmc-tab.is-active {
  background: var(--color-bg-hero);
  border-color: var(--color-bg-hero);
  color: var(--color-accent-lime);
}

.tmc-tab__num {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  opacity: 0.6;
}

.tmc-tab.is-active .tmc-tab__num {
  opacity: 0.8;
}

.tmc-tab__label {
  font-size: 0.88rem;
  font-weight: 600;
  text-transform: capitalize;
}

/* ── Panel ── */
.tmc-panel {
  display: none;
  animation: fadeIn 0.3s ease;
}

.tmc-panel.is-active {
  display: block;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.tmc-panel__layout {
