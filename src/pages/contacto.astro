---
// src/pages/trabaja-conmigo.astro
// Inspirada en la estructura de pxldesignlab.com/contact:
// Hero marquee → Servicios numerados con acordeón → Testimonios → Formulario
import BaseLayout from '../layouts/BaseLayout.astro';

const FORMSPREE_ID = 'xykdondo';

const servicios = [
  {
    num: '01',
    tag: 'auditoría',
    titulo: 'Auditoría de marca / web',
    bajada:
      'Solo feedback — no incluye rediseño. Entregado en 7 días.',
    descripcion:
