---
// src/pages/links.astro
// Página de enlaces para Instagram (link in bio).
// No aparece en el menú. URL: /links
// Diseño mobile-first, centrado, sin NavBar.
import '../styles/global.css';

const links = [
  {
    tag: '01 — Auditoría',
    titulo: 'Auditoría web',
    desc: 'Análisis claro de por qué tu web no convierte — y qué cambiar. Entregado en 7 días.',
    cta: 'Reservar auditoría',
    href: '/contacto#servicio-0',
    acento: 'lima',
  },
  {
    tag: '02 — Servicio',
    titulo: 'Landing estratégica',
    desc: 'Una landing ligera, estética y pensada para convertir visitas en conversaciones reales.',
    cta: 'Ver más',
    href: '/contacto#servicio-1',
    acento: 'rosa',
  },
  {
    tag: '03 — Servicio',
    titulo: 'Web personalizada',
    desc: 'Web a medida, diseñada y desarrollada sin plantillas. Todo alineado con tu marca.',
    cta: 'Ver más',
    href: '/contacto#servicio-2',
    acento: 'lila',
  },
  {
    tag: '04 — Plantillas',
    titulo: 'Tienda de plantillas',
    desc: 'Si estás empezando: plantillas web listas para personalizar con tu marca.',
    cta: 'Ver plantillas',
    href: '/tienda',
    acento: 'lima',
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AndreaFusion — Diseño y desarrollo web con personalidad." />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#3D1A5C" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>Links — AndreaFusion</title>
  </head>

  <body>
    <main class="links-page">

      <!-- ══════════════════════════════════════
           PERFIL
      ══════════════════════════════════════ -->
      <header class="links-profile">

        <!-- Avatar -->
        <div class="links-avatar" aria-hidden="true">
          <img
            src="/andrea.webp"
            alt="Andrea, diseñadora web"
            class="links-avatar__photo"
          />
          <div class="links-avatar__ring"></div>
        </div>

        <!-- Nombre + tagline -->
        <div class="links-profile__text">
          <h1 class="links-profile__name">AndreaFusion</h1>
          <p class="links-profile__tagline">
            Webs con personalidad que conectan.<br>
            <em>Diseño + Código — Based in Spain.</em>
          </p>
        </div>

        <!-- Botón "Ir a la web" -->
        <a href="/" class="links-profile__web-btn">
          Ver mi web
          <span aria-hidden="true">↗</span>
        </a>

      </header>

      <!-- ══════════════════════════════════════
           TARJETAS DE ENLACE
      ══════════════════════════════════════ -->
      <ul class="links-list" role="list">
        {links.map((l) => (
          <li class={`links-card links-card--${l.acento}`}>
            <div class="links-card__body">
              <p class="links-card__tag">{l.tag}</p>
              <h2 class="links-card__titulo">{l.titulo}</h2>
              <p class="links-card__desc">{l.desc}</p>
            </div>
            <a href={l.href} class="links-card__btn" aria-label={`${l.cta} — ${l.titulo}`}>
              <span>{l.cta}</span>
              <span class="links-card__arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ul>

      <!-- ══════════════════════════════════════
           PIE
      ══════════════════════════════════════ -->
      <footer class="links-footer">
        <p>© 2025 AndreaFusion</p>
        <a href="https://instagram.com" class="links-footer__ig" aria-label="Instagram de Andrea">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4.5"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
          @andrea.morant
        </a>
      </footer>

    </main>
  </body>
</html>

<style>
  /* ══════════════════════════════════
     TOKENS (mismo global.css)
  ══════════════════════════════════ */
  :root {
    --color-bg-hero:    #3d1a5c;
    --color-bg-light:   #ede4f5;
    --color-accent-lime:#c8f135;
    --color-accent-pink:#f5b8d0;
    --color-text-hero:  #f5eee6;
    --color-text-dark:  #1a0a2e;
    --color-text-mid:   #5a3a7a;
    --font-display: "Playfair Display", Georgia, serif;
    --font-body:    "DM Sans", system-ui, sans-serif;
    --font-script:  "Caveat", cursive;
    --radius-btn:   9999px;
    --radius-card:  2rem;
  }


  *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

  body {
    font-family: var(--font-body);
    background: var(--color-bg-hero);
    color: var(--color-text-hero);
    min-height: 100dvh;
    overflow-x: hidden;
  }

  a { color: inherit; text-decoration: none; }

  ::selection {
    background: rgba(200, 241, 53, 0.35);
    color: var(--color-text-dark);
  }

  :focus-visible {
    outline: 2.5px solid var(--color-accent-lime);
    outline-offset: 3px;
    border-radius: 4px;
  }

  /* ══════════════════════════════════
     PÁGINA
  ══════════════════════════════════ */
  .links-page {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1.25rem 4rem;
    gap: 2.5rem;
    /* Fondo con gradiente radial sutil — mismo lenguaje que el resto */
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%,
        rgba(200, 241, 53, 0.07) 0%,
        transparent 70%),
      radial-gradient(ellipse 60% 40% at 90% 80%,
        rgba(245, 184, 208, 0.08) 0%,
        transparent 65%),
      var(--color-bg-hero);
  }

  /* ══════════════════════════════════
     PERFIL
  ══════════════════════════════════ */
  .links-profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
    width: 100%;
    max-width: 420px;
  }

  /* Avatar */
  .links-avatar {
    position: relative;
    width: 88px;
    height: 88px;
    flex-shrink: 0;
  }

  .links-avatar__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center; /* ajusta si tu cara no queda centrada */
    border-radius: 50%;
    z-index: 1;
  }

  /* Anillo animado */
  .links-avatar__ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: conic-gradient(
      var(--color-accent-lime) 0%,
      var(--color-accent-pink) 40%,
      var(--color-bg-light) 70%,
      var(--color-accent-lime) 100%
    );
    animation: spin 4s linear infinite;
    z-index: 0;
  }

  .links-avatar__ring::after {
    content: '';
    position: absolute;
    inset: 3px;
    background: var(--color-bg-hero);
    border-radius: 50%;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .links-avatar__ring { animation: none; }
  }

  /* Texto de perfil */
  .links-profile__text {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .links-profile__name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.75rem;
    letter-spacing: -0.03em;
    color: var(--color-text-hero);
  }

  .links-profile__tagline {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.65;
    color: rgba(245, 238, 230, 0.65);
  }

  .links-profile__tagline em {
    font-style: italic;
    color: rgba(245, 238, 230, 0.45);
    font-size: 0.82rem;
    display: block;
    margin-top: 0.15rem;
  }

  /* Botón web */
  .links-profile__web-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55em 1.6em;
    border: 1.5px solid rgba(245, 238, 230, 0.25);
    border-radius: var(--radius-btn);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(245, 238, 230, 0.75);
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
    letter-spacing: 0.02em;
  }

  .links-profile__web-btn:hover {
    border-color: var(--color-accent-lime);
    color: var(--color-accent-lime);
    background: rgba(200, 241, 53, 0.06);
  }

  /* ══════════════════════════════════
     DIVISOR
  ══════════════════════════════════ */
  .links-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 420px;
  }

  /* ══════════════════════════════════
     TARJETAS
  ══════════════════════════════════ */
  .links-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(245, 238, 230, 0.1);
    border-radius: var(--radius-card);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .links-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    border-radius: var(--radius-card) var(--radius-card) 0 0;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .links-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(245, 238, 230, 0.2);
    transform: translateY(-2px);
  }

  .links-card:hover::before {
    opacity: 1;
  }

  /* Variantes de acento — línea superior */
  .links-card--lima::before  { background: var(--color-accent-lime); }
  .links-card--rosa::before  { background: var(--color-accent-pink); }
  .links-card--lila::before  { background: var(--color-bg-light); }

  /* Cuerpo de la tarjeta */
  .links-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .links-card__tag {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245, 238, 230, 0.4);
  }

  .links-card--lima .links-card__tag { color: rgba(200, 241, 53, 0.7); }
  .links-card--rosa .links-card__tag { color: rgba(245, 184, 208, 0.7); }
  .links-card--lila .links-card__tag { color: rgba(237, 228, 245, 0.5); }

  .links-card__titulo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-text-hero);
  }

  .links-card__desc {
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.65;
    color: rgba(245, 238, 230, 0.58);
    margin-top: 0.25rem;
  }

  /* Botón interno */
  .links-card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.8em 1.5em;
    border-radius: var(--radius-btn);
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 700;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    align-self: stretch;
  }

  /* Colores del botón según variante */
  .links-card--lima .links-card__btn {
    background: var(--color-accent-lime);
    color: var(--color-text-dark);
    box-shadow: 0 4px 18px rgba(200, 241, 53, 0.25);
  }

  .links-card--lima .links-card__btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 28px rgba(200, 241, 53, 0.4);
  }

  .links-card--rosa .links-card__btn {
    background: rgba(245, 184, 208, 0.15);
    border: 1px solid rgba(245, 184, 208, 0.35);
    color: var(--color-text-hero);
  }

  .links-card--rosa .links-card__btn:hover {
    background: rgba(245, 184, 208, 0.25);
    transform: translateY(-1px);
  }

  .links-card--lila .links-card__btn {
    background: rgba(237, 228, 245, 0.1);
    border: 1px solid rgba(237, 228, 245, 0.25);
    color: var(--color-text-hero);
  }

  .links-card--lila .links-card__btn:hover {
    background: rgba(237, 228, 245, 0.18);
    transform: translateY(-1px);
  }

  .links-card__arrow {
    font-size: 1rem;
    transition: transform 0.18s ease;
  }

  .links-card__btn:hover .links-card__arrow {
    transform: translate(2px, -2px);
  }

  /* ══════════════════════════════════
     PIE
  ══════════════════════════════════ */
  .links-footer {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: rgba(245, 238, 230, 0.3);
    letter-spacing: 0.04em;
  }

  .links-footer__ig {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 0.2s ease;
  }

  .links-footer__ig:hover {
    color: rgba(245, 238, 230, 0.7);
  }

  /* ══════════════════════════════════
     SCROLLBAR
  ══════════════════════════════════ */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--color-bg-hero); }
  ::-webkit-scrollbar-thumb {
    background: var(--color-accent-lime);
    border-radius: 99px;
  }
</style>