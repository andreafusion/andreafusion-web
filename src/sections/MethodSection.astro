---
// src/sections/MethodSection.astro
// Sección 02 — Mi método
// Los 4 pasos se renderizan en HTML estático (SEO + no-JS).
// Al entrar en viewport aparecen uno a uno desde la izquierda.

const STEPS = [
  {
    num:   '01',
    title: 'Diagnóstico sin piedad',
    titleEm: '(pero con cariño)',
    text:  'Encuentro dónde se cae la confianza y por qué la gente se va.',
  },
  {
    num:   '02',
    title: 'Guión de',
    titleEm: 'scroll',
    text:  'Te marco el camino: qué ves primero, qué entiendes y cuándo haces clic.',
  },
  {
    num:   '03',
    title: 'Frontend',
    titleEm: 'fino',
    text:  'Lo convierto en una web rápida, móvil perfecta y cero fricción.',
  },
  {
    num:   '04',
    title: 'Pulido',
    titleEm: 'quirúrgico',
    text:  'Recorto lo que sobra, afino lo que importa y dejo solo lo que funciona.',
  },
];
---

<section class="method" id="metodo" aria-labelledby="method-heading">
  <div class="method__inner">

    <!-- Eyebrow -->
    <p class="method__eyebrow kicker muted" aria-hidden="true">02 · Mi método</p>

    <!-- Titular editorial -->
    <header class="method__header">
      <h2 class="method__title" id="method-heading">
        Primero te ordeno<br>
        <em>la historia.</em><br>
        Luego te programo la web.
      </h2>
      <p class="method__subtitle lead">
        Porque "bonita" no sirve si confunde.<br>
        Yo hago que se entienda y que pase algo.
      </p>
    </header>

    <!-- 4 pasos estáticos -->
    <ol class="method__steps" id="method-steps" aria-label="Pasos del método">
      {STEPS.map((step, i) => (
        <li class="method__panel" style={`--i: ${i}`}>
          <span class="method__step-num" aria-hidden="true">{step.num}</span>
          <h3 class="method__step-title">
            {step.title} <em>{step.titleEm}</em>
          </h3>
          <p class="method__step-text">{step.text}</p>
        </li>
      ))}
    </ol>

  </div><!-- /.method__inner -->

  <!-- Nota final -->
  <footer class="method__footer">
    <div class="method__footer-inner">
      <p class="method__note">
        Si no hay guión, el usuario improvisa.<br>
        Y cuando improvisa… <em>se va.</em>
      </p>
    </div>
  </footer>

</section>

<script>
  const steps = document.querySelectorAll<HTMLElement>('.method__panel');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reducedMotion) {
    // Sin animación: todos visibles desde el inicio
    steps.forEach(el => el.classList.add('is-visible'));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.15,      // dispara cuando el 15% del paso es visible
        rootMargin: '0px 0px -60px 0px', // un poco antes del borde inferior
      }
    );

    steps.forEach(el => observer.observe(el));
  }
</script>

<style>
  /* ── Layout base ── */
  .method {
    position: relative;
    z-index: 11;
    background: #fff;
    overflow: hidden;
  }

  .method__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 1.5rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* ── Eyebrow ── */
  .method__eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.65rem, 1.8vw, 0.8rem);
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-mid);
    opacity: 0.6;
  }

  /* ── Header ── */
  .method__header {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .method__title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--text-h1);
    line-height: 1.05;
    letter-spacing: normal;
    color: var(--color-text-dark);
  }

  .method__title em {
    font-style: italic;
    font-family: var(--font-display);
    color: var(--color-accent-lime);
    font-weight: 400;
  }

  .method__subtitle {
    font-family: var(--font-body);
    font-size: var(text-subtitle);
    line-height: 1.7;
    color: var(--color-text-mid);
    max-width: 44ch;
  }

  /* ── Lista de pasos ── */
  .method__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* ── Panel / paso ── */
  .method__panel {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    /* Estado inicial: invisible y desplazado a la izquierda */
    opacity: 0;
    transform: translateX(-48px);
    transition:
      opacity  0.5s ease,
      transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);

    /* Cada paso añade un retraso según su índice (--i definido en el HTML) */
    transition-delay: calc(var(--i) * 0.12s);
  }

  /* Estado visible: disparado por JS al entrar en viewport */
  .method__panel.is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  .method__step-num {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 12vw, 7rem);
    font-weight: 900;
    line-height: 1;
    color: var(--color-accent-pink);
    opacity: 0.40;
    letter-spacing: normal;
    pointer-events: none;
    user-select: none;
  }

  .method__step-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4.5vw, 3rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: normal;
    color: var(--color-text-dark);
    margin-top: -0.45em; /* superponer sobre número decorativo */
  }

  .method__step-title em {
    font-style: italic;
    font-family: var(--font-display);
    color: var(--color-accent-lime);
    font-weight: 400;
  }

  .method__step-text {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    line-height: 1.75;
    color: var(--color-text-mid);
    max-width: 48ch;
  }

  /* ── Nota final ── */
  .method__footer {
    padding-top: 1.5rem;
    border-top: 1px solid rgba(26, 10, 46, 0.08);
  }

  .method__footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }

  .method__note {
    font-family: var(--font-script);
    font-size: clamp(1.1rem, 2.8vw, 1.6rem);
    font-style: italic;
    line-height: 1.5;
    color: var(--color-text-dark);
    max-width: 42ch;
  }

  .method__note em {
    color: var(--color-accent-lime);
  }

  /* ── Reduced motion: sin transición ── */
  @media (prefers-reduced-motion: reduce) {
    .method__panel {
      transition: none;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 768px) {
    .method__inner {
      padding: 8rem 4rem 7rem;
      gap: 5rem;
    }

    .method__footer-inner {
      padding: 0 4rem 7rem;
    }
  }

  @media (min-width: 1024px) {
    .method__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: 6rem;
      align-items: start;
    }

    .method__eyebrow { grid-column: 1 / -1; }
    .method__header  { grid-column: 1; position: sticky; top: 8rem; }
    .method__steps   { grid-column: 2; }
  }
</style>